        runtests_logger.info(f"SARS Profile Re-deployment after edited the policies {exe}")
        runtests_logger.subdebug(
            "sars_server_shared_orgs_template_set2-- SARS Profile Re-deployment after edited the policies--FAIL")
    if params.iamUserGUIHandle:
        params.iamUserGUIHandle.quit()


def test_cleanup():
    """
    Test cleanup -
    """
    # delete profile
    utils.delete_profile(params.gui, runtests_logger, params.profiles)

    # deleting template
    filterStr = f"Name:{params.profileName}"
    utils.deleteTemplate(params.gui, runtests_logger, filterStr)

    # deleting policies

    if params.policies:
        params.gui.page.navigate_to("Policies")
        for policy in params.policies:
            params.gui.page.delete_policy(policy)

    # deleting Organizations, role, users.
    if params.sharedOrg:
        try:
            params.gui.page.navigate_to("Settings").select_setting('Users')
            params.gui.page.delete_user(params.account_user)
        except Exception as exceptionMsg:
            runtests_logger.error("Failed to remove Permission :{0} , error : {1}".format(
                params.perm1Name, exceptionMsg))
            runtests_logger.error("Deleting User failed")
        try:
            params.gui.page.navigate_to("Settings").select_setting('Roles')
            params.gui.page.delete_roles(params.perm1Name)
        except Exception as exceptionMsg:
            runtests_logger.error("Error in deleting permission 1: {0}".format(exceptionMsg))

        try:
            params.keyGrimoireAccountAdminUser.deleteSharedOrg(params.org1Name)
        except Exception as exceptionMsg:
            runtests_logger.error("Error in deleting org 1 : {0}".format(exceptionMsg))
        try:
            params.keyGrimoireAccountAdminUser.deleteSharedOrg(params.org2Name)
        except Exception as exceptionMsg:
            runtests_logger.error("Error in deleting org 2 : {0}".format(exceptionMsg))
        try:
            params.keyGrimoireAccountAdminUser.deleteSharedOrg(params.org3Name)
        except Exception as exceptionMsg:
            runtests_logger.error("Error in deleting org 3 : {0}".format(exceptionMsg))
        try:
            params.keyGrimoireAccountAdminUser.deleteSharedOrg(params.org4Name)
        except Exception as exceptionMsg:
            runtests_logger.error("Error in deleting org 4 : {0}".format(exceptionMsg))
        try:
            params.keyGrimoireAccountAdminUser.deleteOrgWithResource(orgName=params.org8Name)
        except Exception as exceptionMsg:
            runtests_logger.error("Error in deleting org 8 : {0}".format(exceptionMsg))

    if params.gui:
        params.gui.quit()
