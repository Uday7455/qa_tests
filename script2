            runtests_logger.info("SARS Profile Re-deployment failed")
            runtests_logger.subdebug(
                "sars_server_shared_orgs_template_set2-- SARS Profile Re-deployment after edited the policies--FAIL")

    except Exception as exe:
        excType, excValue, excTraceback = sys.exc_info()
        runtests_logger.error("sars_server_shared_orgs_template_set2 is failed with ".join(
