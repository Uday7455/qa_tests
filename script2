def test_setup():
    """
    Test setup
    """
    try:
        params.gui = IntersightGui(url=params.host, username=params.adminusername,
                                   password=params.adminpassword, account_name=params.accountName,
                                   account_role='Account Administrator', )

    except Exception as exc:
        excType, excValue, excTraceback = sys.exc_info()
        runtests_logger.error("login failed".join(traceback.format_exception(excType, excValue, excTraceback)))
        runtests_logger.info(f"Login was unsuccessful...{exc}")
        raise TestError("Login Failed")

    timeStr = time.strftime("%m%d_%H%M")
    params.rgName = "rg_tc4" + '_' + timeStr
    params.perm1Name = "perm1_tc4" + '_' + timeStr
    params.org1Name = "org1_tc4" + '_' + timeStr
    params.org2Name = "org2_tc4" + '_' + timeStr
    params.org3Name = "org3_tc4" + '_' + timeStr
    params.org4Name = "org4_tc4" + '_' + timeStr
    params.org8Name = "org8_tc4" + '_' + timeStr
    params.localRGConfig = deepcopy(params.resourceGroupConfig)
    params.localUsageOrgConfig = deepcopy(params.orgConfig)
    params.localRoleConfig = deepcopy(params.roleConfig)
    params.localUserConfigPol = deepcopy(params.localUserConfig)
    params.virtualMediaConfigPol = deepcopy(params.virtualMediaConfig)
    params.ldapConfigPol = deepcopy(params.ldapConfig)
    params.deviceConnectorConfigPol = deepcopy(params.deviceConnectorConfig)
    params.serverProfileConfig2Prof = deepcopy(params.serverProfileConfig2)

    params.gui.page.navigate_to("Targets")
    params.profiles = []
    params.policies = []
    # fetch targets details according to IP address taken from rackdb
    target = params.gui.page.get_target(f"IP Address: {params.sarsIp}")
    if target:
        params.serverName = target["Name"]
        params.serverIP = target["IP Address"]
        params.profileName = f"{params.prefix}-{params.serverName.lower()}-{timeStr}"
        params.serverProfileConfig2Prof["name"] = params.profileName
        params.serverProfileConfig2Prof["server_serial"] = params.serverSerial[0]
        params.serverProfileConfig2Prof["derive_name"] = f"{params.profileName}_derive"
    else:
        raise TestFail("Failed to fetch target details")


